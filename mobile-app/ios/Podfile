# Cactus needs 15+, flutter_gemma needs 16+.
platform :ios, '16.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  # MediaPipe + TensorFlowLite ship as static .xcframeworks. Build all pods
  # as static so they coexist cleanly with flutter_gemma's transitive deps.
  use_frameworks! :linkage => :static

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end

  # The vendored cactus_util.framework (cactus 1.3.0, pub.dev) ships with a
  # stripped Info.plist that has no MinimumOSVersion. App Store validation
  # rejects it with "Apps that only support 64-bit devices must specify a
  # deployment target of 8.0 or later." Append a patch step to the generated
  # xcframeworks copy script so the build-dir slice gets a valid Info.plist
  # before Xcode embeds and signs it into Runner.app.
  xcframeworks_script_path = File.join(__dir__, 'Pods', 'Target Support Files', 'cactus', 'cactus-xcframeworks.sh')
  if File.exist?(xcframeworks_script_path)
    sentinel = '# CACTUS_UTIL_INFO_PLIST_PATCH_V1'
    contents = File.read(xcframeworks_script_path)
    unless contents.include?(sentinel)
      File.open(xcframeworks_script_path, 'a') do |f|
        f.puts ''
        f.puts sentinel
        f.puts 'INFO_PLIST="${PODS_XCFRAMEWORKS_BUILD_DIR}/cactus/cactus_util.framework/Info.plist"'
        f.puts 'if [ -f "$INFO_PLIST" ]; then'
        f.puts '  plutil -remove MinimumOSVersion "$INFO_PLIST" >/dev/null 2>&1 || true'
        f.puts '  plutil -insert MinimumOSVersion -string "16.0" "$INFO_PLIST"'
        f.puts '  plutil -remove CFBundleSupportedPlatforms "$INFO_PLIST" >/dev/null 2>&1 || true'
        f.puts '  plutil -insert CFBundleSupportedPlatforms -json \'["iPhoneOS"]\' "$INFO_PLIST"'
        f.puts '  plutil -remove UIRequiredDeviceCapabilities "$INFO_PLIST" >/dev/null 2>&1 || true'
        f.puts '  plutil -insert UIRequiredDeviceCapabilities -json \'["arm64"]\' "$INFO_PLIST"'
        f.puts '  plutil -replace CFBundleName -string "cactus_util" "$INFO_PLIST" >/dev/null 2>&1 || \\'
        f.puts '    plutil -insert CFBundleName -string "cactus_util" "$INFO_PLIST"'
        f.puts '  echo "Patched cactus_util.framework Info.plist (MinimumOSVersion=16.0)"'
        f.puts 'fi'
      end
    end
  end

  # Patch native_assets framework Info.plists to declare MinimumOSVersion=16.0.
  # flutter_gemma's hook/build.dart wraps stripped dylibs into .frameworks with
  # Info.plist MinimumOSVersion="13.0", but the underlying Mach-O binaries are
  # built with minos 14–16. App Store validation flags ITMS-90208 ("bundle does
  # not support the minimum OS Version specified in the Info.plist") when the
  # binary's minos exceeds the plist's MinimumOSVersion. Bumping the plist to
  # 16.0 (matching the app's deployment target) is correct since the binaries
  # require iOS 14–16+ anyway. dSYM stub generation also runs from here so it
  # finds the patched frameworks already in TARGET_BUILD_DIR.
  frameworks_script_path = File.join(__dir__, 'Pods', 'Target Support Files', 'Pods-Runner', 'Pods-Runner-frameworks.sh')
  if File.exist?(frameworks_script_path)
    sentinel = '# VENDORED_FRAMEWORK_PATCHES_V3'
    contents = File.read(frameworks_script_path)
    unless contents.include?(sentinel)
      File.open(frameworks_script_path, 'a') do |f|
        f.puts ''
        f.puts sentinel
        f.puts 'for fw in GemmaModelConstraintProvider LiteRtMetalAccelerator StreamProxy LiteRtLm objective_c sqlite3; do'
        f.puts '  plist="${TARGET_BUILD_DIR}/${FRAMEWORKS_FOLDER_PATH}/${fw}.framework/Info.plist"'
        f.puts '  if [ -f "$plist" ]; then'
        f.puts '    plutil -replace MinimumOSVersion -string "16.0" "$plist" >/dev/null 2>&1 || \\'
        f.puts '      plutil -insert MinimumOSVersion -string "16.0" "$plist"'
        f.puts '    echo "Patched ${fw}.framework Info.plist MinimumOSVersion=16.0"'
        f.puts '  fi'
        f.puts 'done'
        f.puts ''
        f.puts '# Stub .dSYM bundles for vendored binary frameworks that ship without'
        f.puts '# dSYMs. See ios/scripts/make_stub_dsyms.sh. Runs only during archive.'
        f.puts 'if [ "${ACTION:-}" = "install" ] && [ -n "${DWARF_DSYM_FOLDER_PATH:-}" ]; then'
        f.puts '  "${SRCROOT}/scripts/make_stub_dsyms.sh" \\'
        f.puts '    "${TARGET_BUILD_DIR}/${FRAMEWORKS_FOLDER_PATH}" \\'
        f.puts '    "${DWARF_DSYM_FOLDER_PATH}"'
        f.puts 'fi'
      end
    end
  end
end
